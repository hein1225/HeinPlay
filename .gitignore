# Plan folder contains design docs, reference projects and assets.
# These should not be tracked by git.
plan/

# Flutter / Dart build artifacts
.dart_tool/
build/
.packages
.pub-cache/
.flutter-plugins
.flutter-plugins-dependencies

# IDE
.idea/
.vscode/
*.iml
*.ipr
*.iws
.atom/

# OS files
.DS_Store
Thumbs.db

# Android signing & local config (global)
*.jks
key.properties
local.properties

# =====================
# hain_tv project specific
# =====================

# Flutter/Dart Pub related
/hain_tv/**/doc/api/
/hain_tv/**/ios/Flutter/.last_build_id
/hain_tv/.pub/
/hain_tv/.flutter-plugins-dependencies
/hain_tv/pub-cache/

# Symbolication / Obfuscation
/hain_tv/app.*.symbols
/hain_tv/app.*.map.json

# Android Studio build artifacts
/hain_tv/android/app/debug/
/hain_tv/android/app/profile/
/hain_tv/android/app/release/
/hain_tv/android/.kotlin/

# Signing keys and passwords should never be committed
/hain_tv/android/key.properties
/hain_tv/android/key-mobile.properties
/hain_tv/android/*.keystore
/hain_tv/android/*.jks

# Distribution / build outputs
/hain_tv/dist/

# Windows runtime logs / debug temp files
/hain_tv/data/windows_logs/
/hain_tv/windows_log*.txt
/hain_tv/windows_log*.md
/hain_tv/*.log
/hain_tv/*.tmp
/hain_tv/*.temp

# Generic runtime logs
data/windows_logs/
*.log
*_log*.txt
*_log*.md
*.tmp
*.temp
